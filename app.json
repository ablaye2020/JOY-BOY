  "logo": "https://files.catbox.moe/6zd0ru.jpg",
  "keywords": ["ZETSU-MD", "JOYBOY"],
  "success_url": "/",
  "stack": "container",
  "env": {
    "SESSION_ID": {
      "description": "Put the session-id here. (Required)",
      "required": true,
      "value": ""
    },
    "PREFIX": {
      "description": "Bot prefix (Default: .)",
      "required": false,
      "value": "."
    },
    "BOT_NAME": {
      "description": "Your bot name (Default: ZETSU-MD)",
      "required": false,
      "value": "𝐙𝐄𝐓𝐒𝐔-MD"
    },
    "MODE": {
      "description": "Bot mode: public/private/inbox/groups (Default: public)",
      "required": false,
      "value": "public"
    },
    "OWNER_NUMBER": {
      "description": "Owner WhatsApp number without + (Default: 77XXXXXXXX)",
      "required": false,
      "value": "77XXXXXXXX"
    },
    "OWNER_NAME": {
      "description": "Owner name (Default: JOYBOY)",
      "required": false,
      "value": "JOYBOY"
    },
    "AUTO_REPLY": {
      "description": "Auto reply to messages: true/false (Default: false)",
      "required": false,
      "value": "true"
    },
    "READ_MESSAGE": {
      "description": "Auto read messages: true/false (Default: true)",
      "required": false,
      "value": "true"
    },
    "AUTO_REACT": {
      "description": "Auto react to messages: true/false (Default: true)",
      "required": false,
      "value": "true"
    },
    "OWNER_REACT": {
      "description": "Owner auto react: true/false (Default: true)",
      "required": false,
      "value": "true"
    },
    "ALWAYS_ONLINE": {
      "description": "Always online mode: true/false (Default: true)",
      "required": false,
      "value": "true"
