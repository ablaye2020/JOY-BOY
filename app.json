      "description": "Goodbye message with placeholders",
      "required": false,
      "value": "*_⚔️ @user a quitté le groupe - 𝐙𝐄𝐓𝐒𝐔-MD ⚔️_*"
    },
    "BOT_MEDIA_URL": {
      "description": "Bot media URL",
