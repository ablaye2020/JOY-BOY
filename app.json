      "description": "Auto downloader: true/false (Default: false)",
      "required": false,
      "value": "false"
    },
    "ADMIN_ACTION": {
      "description": "Admin action notifications: true/false (Default: true)",
      "required": false,
      "value": "true"
    },
    "DESCRIPTION": {
      "description": "Bot description",
      "required": false,
      "value": "*⚔️ 𝐙𝐄𝐓𝐒𝐔-MD - WhatsApp Bot | \"Le respect ne se demande pas\" - JOYBOY ⚔️*"
