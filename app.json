    "AUTO_TYPING": {
      "description": "Auto typing: true/false/inbox/group (Default: true)",
      "required": false,
      "value": "true"
    },
    "AUTO_RECORDING": {
      "description": "Auto recording: true/false/inbox/group (Default: false)",
      "required": false,
      "value": "false"
    },
    "ANTI_LINK": {
      "description": "Anti-link mode: true/warn/delete/false (Default: true)",
      "required": false,
      "value": "true"
    },
    "ANTI_DELETE": {
      "description": "Anti delete: true/false (Default: true)",
      "required": false,
      "value": "true"
    },
    "ANTI_DELETE_PATH": {
      "description": "Anti delete path: inbox/group/all (Default: inbox)",
      "required": false,
      "value": "inbox"
    },
    "ANTI_EDIT": {
      "description": "Anti edit: true/false (Default: true)",
      "required": false,
      "value": "true"
    },
    "ANTIEDIT_PATH": {
      "description": "Anti edit path: inbox/group/all (Default: inbox)",
      "required": false,
      "value": "inbox"
